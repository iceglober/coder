{
  "name": "coder-server",
  "version": "0.0.0",
  "private": true,
  "description": "coder agent server: Router, AI SDK loop, tools, Capabilities, Extractors, Succinctness controller, context-manager, Ledger, telemetry (OTel+Counted), Distiller, registry, SSE. Runs sandboxed per-worktree.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "coder-server": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "echo 'no linter configured yet'"
  },
  "dependencies": {
    "coder-core": "workspace:*",
    "ai": "^7",
    "@ai-sdk/anthropic": "^4",
    "@ai-sdk/google-vertex": "^5",
    "@ai-sdk/openai-compatible": "^3",
    "@counted/sdk": "^0.1.0",
    "@opentelemetry/api": "^1",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22",
    "typescript": "^5"
  },
  "license": "MIT"
}
