{
  "name": "coder-tui",
  "version": "0.0.0",
  "private": true,
  "description": "coder host client: Ink TUI — chat pane + / palette + proposals review + status bar, beside a real shell pane (tmux). Connects to the sandboxed agent server over SSE.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outdir=dist --external react-devtools-core",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "echo 'no linter configured yet'"
  },
  "dependencies": {
    "coder-core": "workspace:*",
    "coder-server": "workspace:*",
    "ink": "^5",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22",
    "@types/react": "^18.3.0",
    "typescript": "^5"
  },
  "license": "MIT"
}
